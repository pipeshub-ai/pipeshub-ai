[run]
source = app
branch = True
omit =
    # Auto-generated REST API wrappers (30+ external services, 60k+ lines)
    app/sources/external/*
    # Neo4j provider (future backend, not in use)
    app/services/graph_db/neo4j/*
    # Migration scripts (require live DB with specific state)
    app/migrations/*

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    if __name__ == .__main__
    raise NotImplementedError
    pass
    @abstractmethod

show_missing = True
precision = 1
