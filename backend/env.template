PORT=3000
NODE_ENV=development
LOG_LEVEL=debug
ALLOWED_ORIGINS=http://localhost:3001

SECRET_KEY=my-secret

FRONTEND_PUBLIC_URL=http://localhost:3001
QUERY_BACKEND=http://localhost:8000
CONNECTOR_BACKEND=http://localhost:8088
CONNECTOR_PUBLIC_BACKEND=
INDEXING_BACKEND=http://localhost:8091
EMBEDDING_SERVER_URL=http://localhost:8002
# Security: set to true only if you need models that require custom Python code
# (e.g. nomic-embed-text-v2-moe). Defaults to false to prevent RCE.
EMBEDDING_SERVER_ALLOW_REMOTE_CODE=false
# Optional comma-separated allowlist of model names the embedding server will
# load. When unset, any model name is accepted (original behaviour).
# EMBEDDING_SERVER_ALLOWED_MODELS=BAAI/bge-large-en-v1.5,nomic-ai/nomic-embed-text-v2-moe
DOCLING_BACKEND=http://localhost:8081

# Key-Value Store Configuration
# KV_STORE_TYPE: 'redis' or 'etcd' (default for local dev: redis — no etcd needed)
KV_STORE_TYPE=redis

# ETCD Configuration (only used when KV_STORE_TYPE=etcd; not needed for the
# default Redis-based local setup)
# ETCD_URL=http://localhost:2379
# ETCD_HOST=localhost
# ETCD_TIMEOUT=5000

# Graph database selector: 'neo4j' (default) or 'arangodb'
DATA_STORE=neo4j

# ArangoDB (only used when DATA_STORE=arangodb)
# ARANGO_URL=http://localhost:8529
# ARANGO_DB_NAME=es
# ARANGO_USERNAME=root
# ARANGO_PASSWORD=your_password

# Kafka (only used when MESSAGE_BROKER=kafka; not needed for the default
# Redis Streams setup)
# KAFKA_BROKERS=localhost:9092
# KAFKA_SSL=true
# KAFKA_SASL_MECHANISM=scram-sha-512      # Options: plain, scram-sha-256, scram-sha-512
# KAFKA_USERNAME=
# KAFKA_PASSWORD=

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://:${REDIS_PASSWORD:-}@localhost:6379
# Redis KV store settings (used when KV_STORE_TYPE=redis)
REDIS_DB=0
REDIS_TIMEOUT=10000
REDIS_KV_PREFIX=pipeshub:kv:

MONGO_URI=mongodb://admin:password@localhost:27017/
MONGO_DB_NAME=enterprise-search

QDRANT_API_KEY=your_qdrant_secret_api_key
QDRANT_HOST=localhost
QDRANT_GRPC_PORT=6334
QDRANT_PORT=6333

OLLAMA_API_URL=http://localhost:11434

ACCESS_TOKEN_EXPIRY=24h
REFRESH_TOKEN_EXPIRY=720h

# Neo4j (used when DATA_STORE=neo4j). Works for both Neo4j Desktop and Docker on localhost.
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_password
NEO4J_DATABASE=neo4j

# MCP OAuth scopes (comma-separated)
MCP_SCOPES=openid,profile,email,offline_access,semantic:write,conversation:write,conversation:chat,kb:read,team:read,user:read,config:read

# Message broker: "redis" (default — uses Redis Streams) or "kafka"
MESSAGE_BROKER=redis
# COMPOSE_PROFILES controls optional docker-compose services.
# Leave unset for the default Redis Streams setup (no Kafka/Zookeeper).
# Set COMPOSE_PROFILES=kafka only if you switch MESSAGE_BROKER=kafka.
COMPOSE_PROFILES=
# Redis Streams settings (only used when MESSAGE_BROKER=redis)
REDIS_STREAMS_MAXLEN=10000

# Consumer settings
# Max times a message can be delivered before being dead-lettered (default: 10)
# MAX_DELIVERY_ATTEMPTS=10

# SAML SP Entity ID (Issuer) — must match the Audience URI configured in your IdP.
# Defaults to FRONTEND_PUBLIC_URL if set, otherwise 'pipeshub'.
# SAML_SP_ENTITY_ID=

