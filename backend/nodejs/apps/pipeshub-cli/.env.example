# Pipeshub CLI — copy to .env (optional if defaults are fine)

# Backend base URL (default: http://localhost:3000)
PIPESHUB_BACKEND_URL=http://localhost:3000

# Optional: auth/config directory (default: ~/.config/pipeshub on Unix, %APPDATA%\Pipeshub on Windows)
# PIPESHUB_CONFIG_DIR=~/.config/pipeshub
