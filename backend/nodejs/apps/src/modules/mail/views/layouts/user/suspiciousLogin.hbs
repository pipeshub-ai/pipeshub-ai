<!DOCTYPE html>
<html>
  {{>head}}
  <body>
    <main>
      <table {{{containerstyle}}}>
        <tr>
          <td>{{> header}}</td>
        </tr>
        <tr>
          <td>
            <table class="mobile-width" {{{bodytablestyle}}}>
              <tr>
                <td
                  style="
                    padding: 40px 30px;
                    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
                  "
                >
                  <div
                    style="
                      font-size: 20px;
                      font-weight: 700;
                      color: #1d1c1d;
                      letter-spacing: -0.25px;
                      line-height: 28px;
                      margin: 0 0 16px 0;
                    "
                  >
                    We noticed a suspicious sign-in attempt
                  </div>
                  <div
                    style="
                      font-size: 15px;
                      font-weight: 400;
                      color: #434245;
                      line-height: 22px;
                      margin: 0 0 24px 0;
                    "
                  >
                    <div>{{#if name}}Hi {{name}},{{else}}Hi,{{/if}}</div>
                    <div>We detected multiple failed sign-in attempts on your
                      PipesHub account, and your account has been temporarily
                      locked to keep it safe.</div>
                    <div style="height: 22px; line-height: 22px;">&nbsp;</div>
                    <div>To regain access, please reach out to your
                      organisation&rsquo;s admin and ask them to unlock your
                      account.</div>
                  </div>
                  <div
                    style="
                      font-size: 15px;
                      font-weight: 400;
                      color: #434245;
                      line-height: 22px;
                    "
                  >
                    If you didn&rsquo;t attempt to sign in, please let your
                    admin know so they can review the activity on your account.
                  </div>
                </td>
              </tr>
            </table>
          </td>
        </tr>
        <tr>
          <td>{{> footer}}</td>
        </tr>
      </table>
    </main>
  </body>
</html>
