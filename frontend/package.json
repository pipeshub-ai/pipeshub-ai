{
  "name": "pipeshub",
  "version": "0.1.0",
  "description": "PipesHub Desktop App",
  "author": "PipesHub",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start -p 3001",
    "lint": "next lint",
    "deploy:dev": "bash scripts/deploy-dev.sh",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:headed": "npx playwright test --headed",
    "test:e2e:seed": "npx playwright test --project=seed",
    "test:e2e:users": "npx playwright test tests/e2e/users/",
    "test:e2e:groups": "npx playwright test tests/e2e/groups/",
    "test:e2e:teams": "npx playwright test tests/e2e/teams/",
    "test:e2e:report": "npx playwright show-report",
    "test:e2e:cleanup": "npx playwright test tests/e2e/seed/cleanup.spec.ts --project=seed",
    "test:e2e:coverage": "COVERAGE=true npx playwright test",
    "test:e2e:coverage-report": "npx open-cli coverage/e2e/report.html",
    "build:electron": "node scripts/next-build-electron.mjs",
    "electron:prepare": "node scripts/electron-prepare.mjs",
    "electron:build:mac": "npm run build:electron && npm run electron:prepare && npx electron-builder --mac --config electron-builder.yml --publish never",
    "electron:build:win": "npm run build:electron && npm run electron:prepare && npx electron-builder --win --config electron-builder.yml --publish never",
    "electron:build:mac-win": "npm run build:electron && npm run electron:prepare && npx electron-builder --mac --win --config electron-builder.yml --publish never",
    "electron:dmg": "npm run build && npm run electron:prepare && CSC_IDENTITY_AUTO_DISCOVERY=false npx electron-builder --config electron-builder.yml --mac dmg --publish never"
  },
  "dependencies": {
    "@assistant-ui/react": "^0.12.3",
    "@azure/msal-browser": "^5.6.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@lottiefiles/dotlottie-react": "^0.18.3",
    "@radix-ui/themes": "^3.2.1",
    "@react-oauth/google": "^0.13.4",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vis.gl/react-google-maps": "^1.6.1",
    "@xyflow/react": "^12.10.2",
    "axios": "^1.15.0",
    "chokidar": "^3.6.0",
    "docx-preview": "^0.3.7",
    "dompurify": "^3.4.0",
    "i18next": "^25.8.0",
    "i18next-browser-languagedetector": "^8.2.0",
    "immer": "^11.1.3",
    "lottie-react": "^2.4.1",
    "nanoid": "^5.1.6",
    "next": "^15.5.15",
    "qrcode": "^1.5.4",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-i18next": "^16.5.3",
    "react-markdown": "^10.1.0",
    "react-pdf-highlighter": "^6.1.0",
    "react-player": "^3.4.0",
    "react-syntax-highlighter": "^16.1.0",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "swr": "^2.3.6",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^24.2.0",
    "@types/react": "^19.1.9",
    "@types/react-dom": "^19.1.7",
    "dotenv": "^17.4.2",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.2",
    "monocart-reporter": "^2.10.1",
    "sharp": "^0.34.5",
    "typescript": "^5.9.2"
  }
}