# OAuth refresh tokens for integration tests.
# Copy to .env.refresh_tokens and fill in. Do NOT commit .env.refresh_tokens — it contains secrets.
# Tokens are updated in-place whenever the OAuth provider issues a new refresh token
# (e.g. Atlassian uses rotating refresh tokens).
#
# Pattern: {CONNECTOR_TYPE}_REFRESH_TOKEN=<token>
# Add one entry per OAuth connector that needs refresh-token authentication.
JIRA_REFRESH_TOKEN=
GOOGLE_DRIVE_REFRESH_TOKEN=
