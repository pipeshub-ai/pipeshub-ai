# Copy to .env.local and fill in. Used when .env has PIPESHUB_TEST_ENV=local
# Do not commit .env.local — it contains secrets.

# Local backend
PIPESHUB_BASE_URL=http://localhost:3000

# Leave empty to use PIPESHUB_TEST_USER_* (tests will create OAuth app); or set pre-created app creds
CLIENT_ID=
CLIENT_SECRET=

# Org admin — required when CLIENT_ID/CLIENT_SECRET are empty
PIPESHUB_TEST_USER_EMAIL=
PIPESHUB_TEST_USER_PASSWORD=


TEST_GRAPH_DB_TYPE=neo4j   # arango / neo4j

TEST_NEO4J_URI=bolt://localhost:7687
TEST_NEO4J_USERNAME=neo4j
TEST_NEO4J_PASSWORD=
TEST_NEO4J_DATABASE=neo4j

# TEST_ARANGO_URL=http://localhost:8529
# TEST_ARANGO_USERNAME=root
# TEST_ARANGO_PASSWORD=your_password
# TEST_ARANGO_DB_NAME=es

# Message broker: "kafka" or "redis" (must match the backend's MESSAGE_BROKER)
MESSAGE_BROKER=redis

# Kafka (only needed when MESSAGE_BROKER=kafka)
KAFKA_BOOTSTRAP_SERVERS=localhost:29092

# Redis (used for both KV store and messaging when MESSAGE_BROKER=redis)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Storage credentials — same as .env.example; only for connectors you run
S3_ACCESS_KEY=
S3_SECRET_KEY=
GCS_SERVICE_ACCOUNT_JSON=
AZURE_BLOB_CONNECTION_STRING=
AZURE_FILES_CONNECTION_STRING=

CONFLUENCE_TEST_BASE_URL=
CONFLUENCE_TEST_EMAIL=
CONFLUENCE_TEST_API_TOKEN=

# SharePoint Online integration — paste full text of .crt and .key (usually PEM inside those files; multiline ok in .env.local)
SHAREPOINT_TEST_TENANT_ID=
SHAREPOINT_TEST_CLIENT_ID=
SHAREPOINT_TEST_SHAREPOINT_DOMAIN=
SHAREPOINT_TEST_CERTIFICATE=
SHAREPOINT_TEST_PRIVATE_KEY=
# Optional: comma-separated display names (default: Test Site A,Test Site B,Test Site C)
# SHAREPOINT_TEST_SITE_NAMES=
# Optional: initial sync wait seconds (default 600)
# INTEGRATION_SHAREPOINT_SYNC_TIMEOUT=
