# Git
.git
.gitignore
.gitattributes

# Python
**/__pycache__
**/*.py[cod]
**/*$py.class
**/*.so
**/.Python
**/build/
**/develop-eggs/
**/dist/
**/downloads/
**/eggs/
**/.eggs/
**/parts/
**/sdist/
**/var/
**/wheels/
**/*.egg-info/
**/.installed.cfg
**/*.egg
**/.pytest_cache/
**/.coverage
**/htmlcov/
**/.tox/
**/.nox/
**/.hypothesis/
**/.mypy_cache/
**/.ruff_cache/
**/venv/
**/.venv/
**/env/
**/.env

# Node
**/node_modules/
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/.npm
**/.yarn

# The `**/dist/` exclusion above drops the pre-compiled helper libraries
# (deployment/sandbox/lib/pipeshub-{slides,docs}/dist) which the sandbox
# image loads at runtime as ESM. If these aren't present in the build
# context the Dockerfile falls back to an in-image `npm run build` — but
# that adds a dev-dependency install to every image build, so prefer
# shipping the pre-built output.
!deployment/sandbox/lib/**/dist/
!deployment/sandbox/lib/**/dist/**

# IDE
**/.idea/
**/.vscode/
**/*.swp
**/*.swo
**/*~

# OS
**/.DS_Store
**/Thumbs.db

# Build outputs (we rebuild in Docker)
frontend/dist/
backend/nodejs/apps/dist/

# Documentation
**/*.md
**/docs/
**/README*
**/CHANGELOG*
**/LICENSE*

# …but the coding-sandbox "skills" are markdown files shipped alongside
# the Python package (loaded at runtime by get_document_skill). They MUST
# be included in the image, otherwise pptx/docx generation can't load its
# design guidance.
!backend/python/app/agents/actions/coding_sandbox/skills/
!backend/python/app/agents/actions/coding_sandbox/skills/**

# Tests
**/tests/
**/test/
**/__tests__/
**/*.test.*
**/*.spec.*

# Docker
**/Dockerfile*
**/.dockerignore
**/docker-compose*.yml

# Misc
**/.env*
**/secrets/
**/*.log
**/*.bak
**/*.tmp
